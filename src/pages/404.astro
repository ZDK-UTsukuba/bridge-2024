---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SearchBox from "../components/SearchBox.astro";
import SideMenu from "../components/SideMenu.astro";
import pageStyles from "./404.module.scss";
---

<Layout title="ページが見つかりません - BRIDGE">
    <Header isMain={false}>
        <SearchBox defaultInput={""} styleAttr="margin: 40px 0 20px;" />
    </Header>
    <main class={pageStyles.main}>
        <div class={pageStyles.body}>
            <h1 class={pageStyles.title}>404 Not Found</h1>
            <p>アクセスしたページは見つかりませんでした</p>
        </div>
        <div class={pageStyles.sidebar}>
            <SideMenu />
        </div>
    </main>
</Layout>
