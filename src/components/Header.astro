---
interface Props {
  isMain: boolean;
}

const { isMain } = Astro.props;
import componentStyles from "./Header.module.scss";
import SearchBox from "./SearchBox.astro";
---

<header class:list={[componentStyles.header, isMain && componentStyles.main]}>
  <div class:list={[componentStyles.logoWrap]}>
    <p class={componentStyles.copy}>シラバスだけでは、わからない。</p>
    <a href="/" class={componentStyles.group}>
      <picture>
        <source srcset="/logo-dark.svg" media="(prefers-color-scheme: dark)" />
        <img
          src="/logo-light.svg"
          alt="Logo"
          class:list={[componentStyles.logo, isMain && componentStyles.large]}
        />
      </picture>
    </a>
  </div>
  <SearchBox />
</header>
