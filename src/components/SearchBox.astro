---
interface Props {
  defaultInput?: string;
  styleAttr?: string;
}

const { defaultInput, styleAttr } = Astro.props;
import componentStyles from "./SearchBox.module.scss";
---

<form class={componentStyles.searchBox} action="/search/" onsubmit="location.href = `/search/${document.getElementById('searchInput').value}`; return false;" style={styleAttr ?? ""}>
  <div class={componentStyles.inputWrap}>
    <img src="/search.svg" alt="Search" class={componentStyles.icon} />
    <input
      id="searchInput"
      type="text"
      class={componentStyles.input}
      value={defaultInput ?? ""}
      placeholder=" "
    />
    <div class={componentStyles.suggestions}>
      <div class={`${componentStyles.container}`}>
        <p class={`suggestion-item ${componentStyles.item}`}>確率論</p>
        <p class={`suggestion-item ${componentStyles.item}`}>微分積分</p>
        <p class={`suggestion-item ${componentStyles.item}`}>線形代数</p>
        <p class={`suggestion-item ${componentStyles.item}`}>統計学</p>
        <p class={`suggestion-item ${componentStyles.item}`}>確率論</p>
      </div>
    </div>
  </div>
</form>
